{
  "name": "zoho_twilio_integration_next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --experimental-https",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint .",
    "test": "jest --watch",
    "db:push": "prisma generate && prisma db push",
    "cleanup:duplicates": "node scripts/cleanup-duplicate-messages.js",
    "cleanup:duplicates:dry": "node scripts/cleanup-duplicate-messages.js --dry-run",
    "backfill:tasks": "node --import tsx/esm scripts/backfill-orphaned-tasks.js --dry-run",
    "backfill:tasks:execute": "node --import tsx/esm scripts/backfill-orphaned-tasks.js --execute"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.0",
    "@testing-library/dom": "^10.4.1",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "csv-parser": "^3.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "lucide-react": "^0.453.0",
    "next": "16.2.2",
    "posthog-js": "^1.364.6",
    "posthog-node": "^5.28.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-loader-spinner": "^8.0.2",
    "react-toastify": "^11.0.5",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^4.19.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "16.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-axios": "^4.9.0",
    "nock": "^13.3.8",
    "postcss": "^8.5.8",
    "prisma": "^7.6.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0"
  }
}
