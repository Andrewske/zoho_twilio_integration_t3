generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id            String          @id @default(cuid())
  platform      String
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
  clientId      String
  clientSecret  String
  refreshToken  String?
  accessToken   String?
  authCode      String?
  expiresIn     Int?
  scope         String?
  apiDomain     String?
  StudioAccount StudioAccount[]
  TokenRefresh  TokenRefresh[]
}

model TokenRefresh {
  id          String   @id @default(cuid())
  accountId   String
  accessToken String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  Account     Account  @relation(fields: [accountId], references: [id])

  @@index([accountId])
}

model Studio {
  id             String          @id @default(cuid())
  zohoId         String
  name           String
  managerName    String?
  smsPhone       String?
  callPhone      String?
  active         Boolean         @default(false)
  isAdmin        Boolean         @default(false)
  twilioPhone    String?
  zohoVoicePhone String?
  Message        Message[]
  StudioAccount  StudioAccount[]
  TwilioMessage  TwilioMessage[]
  ZohoWebhook    ZohoWebhook[]
  ZohoTask       ZohoTask[]
}

model StudioAccount {
  studioId  String
  accountId String
  Account   Account @relation(fields: [accountId], references: [id])
  Studio    Studio  @relation(fields: [studioId], references: [id])

  @@id([studioId, accountId])
  @@index([studioId])
  @@index([accountId])
}

model ZohoWebhook {
  id                  String   @id @default(cuid())
  contactId           String?
  firstName           String?
  mobile              String?
  twilioMessageId     String?
  sentWelcomeMessage  Boolean  @default(false)
  sentFollowUpMessage Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")
  studioId            String?
  Studio              Studio?  @relation(fields: [studioId], references: [id])

  @@index([studioId])
}

model TwilioMessage {
  id              String   @id @default(cuid())
  studioId        String?
  contactId       String?
  from            String
  to              String
  message         String?
  twilioMessageId String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  Studio          Studio?  @relation(fields: [studioId], references: [id])

  @@index([studioId])
}

model Message {
  id                String          @id @default(cuid())
  fromNumber        String
  toNumber          String
  studioId          String?
  contactId         String?
  message           String?
  twilioMessageId   String?         @unique
  isWelcomeMessage  Boolean         @default(false)
  isFollowUpMessage Boolean         @default(false)
  retryCount        Int             @default(0)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at")
  provider          MessageProvider @default(twilio)
  zohoMessageId     String?
  status            String?         @default("delivered")
  errorCode         Int?
  errorMessage      String?
  Studio            Studio?         @relation(fields: [studioId], references: [id])
  ZohoTask          ZohoTask[]

  @@index([studioId])
}

model ZohoTask {
  id          String   @id @default(cuid())
  zohoTaskId  String   @unique
  messageId   String?
  studioId    String
  contactId   String?
  taskSubject String?
  taskStatus  String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  Message     Message? @relation(fields: [messageId], references: [id])
  Studio      Studio   @relation(fields: [studioId], references: [id])

  @@index([messageId])
  @@index([studioId])
}

model CronRun {
  id                String    @id @default(cuid())
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  messagesFound     Int       @default(0)
  messagesProcessed Int       @default(0)
  tasksCreated      Int       @default(0)
  tasksLinked       Int       @default(0)
  errors            Int       @default(0)
  errorDetails      String?
}

enum MessageProvider {
  twilio
  zoho_voice
}
